# Gere um valor longo e aleatorio para o Flask.
FLASK_SECRET_KEY=troque-por-um-segredo-longo-e-aleatorio

# Usuario administrativo da interface.
ADMIN_USERNAME=admin

# Gere com:
# python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('sua-senha-forte'))"
# Preferencial para producao:
ADMIN_PASSWORD_HASH=troque-por-um-hash-werkzeug

# Opcional como fallback operacional quando voce nao quiser lidar com o hash no Compose.
ADMIN_PASSWORD=

# Em producao, mantenha 1 quando houver HTTPS na borda.
SESSION_COOKIE_SECURE=1
TZ=America/Sao_Paulo
